---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Parallax decorative orbiting elements -->
  <div id="hero-parallax" class="absolute inset-0 pointer-events-none">
    <div class="parallax-item absolute top-[20%] left-[12%] w-3 h-3 rounded-full bg-blue-400/60" data-depth="0.4"></div>
    <div class="parallax-item absolute top-[30%] right-[15%] w-4 h-4 rounded-full bg-cyan-400/50" data-depth="0.7"></div>
    <div class="parallax-item absolute bottom-[25%] left-[20%] w-2 h-2 rounded-full bg-blue-300/60" data-depth="0.5"></div>
    <div class="parallax-item absolute bottom-[30%] right-[22%] w-3 h-3 rounded-full bg-cyan-300/50" data-depth="0.9"></div>
    <div class="parallax-item absolute top-[50%] left-[8%] w-16 h-16 rounded-xl border border-blue-500/20 rotate-12" data-depth="0.3"></div>
    <div class="parallax-item absolute top-[18%] right-[10%] w-20 h-20 rounded-full border border-cyan-500/15" data-depth="0.6"></div>
  </div>

  <div id="hero-content" class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div data-aos="zoom-in">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass text-sm text-blue-400 mb-8 border border-blue-500/20 pulse-ring">
        <span class="w-2 h-2 rounded-full bg-blue-400"></span>
        Disponible para proyectos
      </div>
    </div>

    <h1 class="font-heading text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold tracking-tight mb-6">
      <span class="block text-white text-glow" data-aos="fade-up" data-aos-delay="100">Manuel Alejandro</span>
      <span class="block gradient-text mt-2" data-aos="fade-up" data-aos-delay="250">de Jesús Castillo</span>
    </h1>

    <div class="mb-8" data-aos="fade-up" data-aos-delay="400">
      <p class="text-lg sm:text-xl text-slate-300 max-w-2xl mx-auto leading-relaxed">
        <span id="typed-text" class="font-medium"></span><span id="type-cursor" class="text-blue-400">|</span>
      </p>
    </div>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4" data-aos="fade-up" data-aos-delay="550">
      <a href="#projects" class="btn-shimmer px-8 py-4 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-500 transition-all hover:-translate-y-0.5 shadow-lg shadow-blue-500/25">
        Ver mis proyectos
      </a>
      <a href="#contact" class="px-8 py-4 glass text-white font-semibold rounded-xl border border-blue-500/20 hover:border-blue-500/40 hover:bg-blue-600/10 transition-all">
        Contáctame
      </a>
    </div>

    <div class="mt-12 flex items-center justify-center gap-6" data-aos="fade-up" data-aos-delay="700">
      <a href="https://github.com/sheluvsale" target="_blank" rel="noopener noreferrer"
         class="p-3 glass rounded-xl text-slate-400 hover:text-white hover:border-blue-500/40 transition-all hover:-translate-y-1 hover:scale-110" aria-label="GitHub">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53.64 1.53.64.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02A9.6 9.6 0 0112 6.8c.85.004 1.71.11 2.51.32 1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z"/></svg>
      </a>
      <a href="https://www.instagram.com/ale.cast_28/" target="_blank" rel="noopener noreferrer"
         class="p-3 glass rounded-xl text-slate-400 hover:text-pink-400 hover:border-pink-500/40 transition-all hover:-translate-y-1 hover:scale-110" aria-label="Instagram">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 01-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 017.8 2zm-.2 2A3.6 3.6 0 004 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 003.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6zm9.65 1.5a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5zM12 7a5 5 0 110 10 5 5 0 010-10zm0 2a3 3 0 100 6 3 3 0 000-6z"/></svg>
      </a>
    </div>
  </div>

  <a href="#about" class="absolute bottom-8 left-1/2 -translate-x-1/2 text-slate-500 hover:text-blue-400 transition-colors animate-bounce" aria-label="Scroll">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
  </a>
</section>

<script>
  // Typing effect
  const phrases = ['Developer', 'Creator', 'Tech Enthusiast', 'Problem Solver'];
  const typedEl = document.getElementById('typed-text');
  let pi = 0;
  let ci = 0;
  let deleting = false;

  function type() {
    if (!typedEl) return;
    const current = phrases[pi];
    if (deleting) {
      ci--;
      typedEl.textContent = current.substring(0, ci);
      if (ci <= 0) {
        deleting = false;
        pi = (pi + 1) % phrases.length;
        setTimeout(type, 400);
        return;
      }
      setTimeout(type, 45);
    } else {
      ci++;
      typedEl.textContent = current.substring(0, ci);
      if (ci >= current.length) {
        deleting = true;
        setTimeout(type, 1600);
        return;
      }
      setTimeout(type, 90);
    }
  }
  type();

  // Parallax on mouse move
  const parallaxItems = document.querySelectorAll<HTMLElement>('.parallax-item');
  const heroContent = document.getElementById('hero-content');
  const heroSection = document.getElementById('hero');

  heroSection?.addEventListener('mousemove', (e) => {
    const cx = window.innerWidth / 2;
    const cy = window.innerHeight / 2;
    const dx = (e.clientX - cx) / cx;
    const dy = (e.clientY - cy) / cy;

    parallaxItems.forEach((item) => {
      const depth = parseFloat(item.dataset.depth || '0.5');
      item.style.transform = `translate(${dx * depth * 40}px, ${dy * depth * 40}px)`;
    });

    if (heroContent) {
      heroContent.style.transform = `translate(${dx * 8}px, ${dy * 8}px)`;
    }
  });

  heroSection?.addEventListener('mouseleave', () => {
    parallaxItems.forEach((item) => { item.style.transform = ''; });
    if (heroContent) heroContent.style.transform = '';
  });

  // Scroll-based parallax fade
  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY;
    if (heroContent && scrolled < window.innerHeight) {
      heroContent.style.opacity = String(Math.max(0, 1 - scrolled / 600));
    }
  }, { passive: true });
</script>

<style>
  .parallax-item {
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }
  #hero-content {
    transition: transform 0.2s ease-out;
    will-change: transform;
  }
</style>
