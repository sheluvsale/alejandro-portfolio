---
---

<section id="projects" class="relative py-24 sm:py-32 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16" data-aos="fade-up">
      <h2 class="text-sm font-semibold text-blue-400 tracking-wider uppercase mb-3">Proyectos</h2>
      <h3 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-white">
        Webs <span class="gradient-text">hechas</span>
      </h3>
      <p class="text-slate-400 text-lg mt-4 max-w-2xl mx-auto">
        Sitios web reales que he desarrollado, listos en producción.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      {[
        {
          name: "Krea Studio",
          url: "https://krea-studio.shop/es",
          domain: "krea-studio.shop",
          desc: "Tienda online moderna con experiencia de usuario fluida, multiidioma y rendimiento optimizado.",
          tags: ["Next.js", "TypeScript"],
          accent: "#3b82f6",
        },
        {
          name: "Vitra Finance",
          url: "https://vitrafinance.com/",
          domain: "vitrafinance.com",
          desc: "Plataforma financiera con interfaz limpia y backend robusto para gestión de servicios.",
          tags: ["PHP", "HTML", "CSS", "JavaScript"],
          accent: "#22d3ee",
        },
        {
          name: "Holguín Tours",
          url: "https://holguintours.vercel.app/",
          domain: "holguintours.vercel.app",
          desc: "Sitio turístico para descubrir destinos, experiencias y servicios en la región de Holguín.",
          tags: ["Astro"],
          accent: "#0ea5e9",
        },
        {
          name: "Proconserh",
          url: "https://proconserh.vercel.app/",
          domain: "proconserh.vercel.app",
          desc: "Página corporativa con presencia profesional, diseño moderno y navegación clara.",
          tags: ["Astro"],
          accent: "#14b8a6",
        },
        {
          name: "Blue Motors",
          url: "https://blue-motors-plum.vercel.app/",
          domain: "blue-motors-plum.vercel.app",
          desc: "Landing page para concesionario de vehículos con estilo dinámico y atractivo.",
          tags: ["Astro"],
          accent: "#6366f1",
        },
        {
          name: "Summa Soft",
          url: "https://summa-soft.vercel.app/",
          domain: "summa-soft.vercel.app",
          desc: "Sitio web de empresa de software con enfoque en soluciones digitales e innovación.",
          tags: ["Astro"],
          accent: "#8b5cf6",
        },
        {
          name: "Agrocopey",
          url: "https://agrocopey.vercel.app/",
          domain: "agrocopey.vercel.app",
          desc: "Plataforma agrícola con información y servicios para el sector productivo.",
          tags: ["Astro"],
          accent: "#22c55e",
        },
      ].map((project, i) => (
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class="project-card card-lift gradient-border rounded-2xl overflow-hidden transition-all block"
          data-aos="fade-up"
          data-aos-delay={i * 120}
        >
          <div class="h-44 flex items-center justify-center relative overflow-hidden" style={`background:linear-gradient(135deg, ${project.accent}22, transparent)`}>
            <div class="absolute inset-0 bg-grid opacity-30"></div>
            <div class="relative text-center px-6">
              <div class="font-heading text-2xl font-bold text-white mb-1">{project.name}</div>
              <div class="text-xs text-slate-400 font-mono">{project.domain}</div>
            </div>
            <div class="project-shine absolute inset-0"></div>
          </div>
          <div class="p-6">
            <div class="flex items-center justify-between mb-3">
              <h4 class="text-xl font-bold text-white">{project.name}</h4>
              <span class="inline-flex items-center gap-1 text-xs text-blue-400">
                Visitar sitio
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M7 17L17 7M17 7H9M17 7v8"/></svg>
              </span>
            </div>
            <p class="text-slate-400 text-sm leading-relaxed mb-4">{project.desc}</p>
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="px-2.5 py-1 text-xs rounded-md glass text-slate-300 border border-blue-500/10">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-16 text-center" data-aos="fade-up">
      <a href="https://github.com/sheluvsale" target="_blank" rel="noopener noreferrer"
         class="btn-shimmer inline-flex items-center gap-2 px-6 py-3 glass rounded-xl text-white font-medium border border-blue-500/20 hover:border-blue-500/40 hover:bg-blue-600/10 transition-all">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53.64 1.53.64.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02A9.6 9.6 0 0112 6.8c.85.004 1.71.11 2.51.32 1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z"/></svg>
        Ver GitHub
      </a>
    </div>

    <div class="mt-24" data-aos="fade-up">
      <div class="text-center mb-16">
        <h2 class="text-sm font-semibold text-blue-400 tracking-wider uppercase mb-3">Edición de videos</h2>
        <h3 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-white">
          Proyectos <span class="gradient-text">audiovisuales</span>
        </h3>
        <p class="text-slate-400 text-lg mt-4 max-w-2xl mx-auto">
          Contenido visual profesional para redes sociales, promociones y eventos.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto">
        <figure class="reel">
          <blockquote
            class="instagram-media"
            data-instgrm-captioned
            data-instgrm-permalink="https://www.instagram.com/reel/DZTtTcOtbTZ/?utm_source=ig_embed&utm_campaign=loading"
            data-instgrm-version="14"
            style="background:#FFF; border:0; border-radius:3px; box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15); margin: 1px auto; max-width:540px; min-width:326px; padding:0; width:calc(100% - 2px);"
          >
          </blockquote>
        </figure>

        <figure class="reel">
          <blockquote
            class="instagram-media"
            data-instgrm-captioned
            data-instgrm-permalink="https://www.instagram.com/reel/DZWCAgguTm4/?utm_source=ig_embed&utm_campaign=loading"
            data-instgrm-version="14"
            style="background:#FFF; border:0; border-radius:3px; box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15); margin: 1px auto; max-width:540px; min-width:326px; padding:0; width:calc(100% - 2px);"
          >
          </blockquote>
        </figure>

        <figure class="reel">
          <blockquote
            class="instagram-media"
            data-instgrm-captioned
            data-instgrm-permalink="https://www.instagram.com/reel/DaDRQKku5ns/?utm_source=ig_embed&utm_campaign=loading"
            data-instgrm-version="14"
            style="background:#FFF; border:0; border-radius:3px; box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15); margin: 1px auto; max-width:540px; min-width:326px; padding:0; width:calc(100% - 2px);"
          >
          </blockquote>
        </figure>
      </div>
    </div>
  </div>
</section>

<script async src="//www.instagram.com/embed.js"></script>

<style>
  .project-shine {
    background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,0.08) 50%, transparent 70%);
    transform: translateX(-100%);
    transition: transform 0.7s ease;
    pointer-events: none;
  }
  .project-card:hover .project-shine {
    transform: translateX(100%);
  }
</style>

