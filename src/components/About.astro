---

<section id="about" class="relative py-24 sm:py-32 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="flex justify-center" data-aos="fade-right">
        <div id="about-tilt" class="relative">
          <img src="/images/logo-sin-fondo.png" alt="Logo Ale" class="w-64 h-64 sm:w-80 sm:h-80 object-contain anim-float" />
          <div class="absolute inset-0 bg-blue-500/15 rounded-full blur-3xl -z-10"></div>
        </div>
      </div>
      <div>
        <h2 class="text-sm font-semibold text-blue-400 tracking-wider uppercase mb-3" data-aos="fade-up">Sobre mí</h2>
        <h3 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6" data-aos="fade-up" data-aos-delay="100">
          Apasionado por la <span class="gradient-text">tecnología</span> y la <span class="gradient-text">creatividad</span>
        </h3>
        <p class="text-slate-400 text-lg leading-relaxed mb-6" data-aos="fade-up" data-aos-delay="200">
          Soy <strong class="text-white">Manuel Alejandro de Jesús Castillo Reyes</strong>, también conocido como <strong class="text-blue-400">Ale</strong>. Me mueve la curiosidad por entender cómo funcionan las cosas y la pasión por crear soluciones digitales que marquen la diferencia.
        </p>
        <p class="text-slate-400 text-lg leading-relaxed mb-6" data-aos="fade-up" data-aos-delay="300">
          Actualmente estoy construyendo mi camino en el mundo del desarrollo, explorando nuevas tecnologías y compartiendo mi proceso en redes sociales. Creo firmemente en el aprendizaje continuo y en el poder de la comunidad tech.
        </p>
        <p class="text-slate-400 text-lg leading-relaxed mb-8" data-aos="fade-up" data-aos-delay="350">
          Además del desarrollo web, soy <strong class="text-white">editor de videos profesional</strong>. He trabajado en <a href="https://www.instagram.com/codify.webagency/" target="_blank" rel="noopener noreferrer" class="text-blue-400 hover:text-blue-300 transition-colors">Codify Web Agency</a>, donde he creado contenido visual impactante para redes sociales, promociones corporativas y highlights de eventos.
        </p>
        <div class="grid grid-cols-3 gap-4" data-aos="fade-up" data-aos-delay="400">
          <div class="gradient-border rounded-xl p-4 text-center">
            <div class="counter font-heading text-3xl font-bold text-white" data-target="1" data-suffix="+">0</div>
            <p class="text-xs text-slate-400 mt-1">Años aprendiendo</p>
          </div>
          <div class="gradient-border rounded-xl p-4 text-center">
            <div class="counter font-heading text-3xl font-bold text-white" data-target="13" data-suffix="+">0</div>
            <p class="text-xs text-slate-400 mt-1">Tecnologías</p>
          </div>
          <div class="gradient-border rounded-xl p-4 text-center">
            <div class="counter font-heading text-3xl font-bold text-white" data-target="100" data-suffix="%">0</div>
            <p class="text-xs text-slate-400 mt-1">Dedicación</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Animated counters
  const counters = document.querySelectorAll<HTMLElement>('.counter');
  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target || '0', 10);
        const suffix = el.dataset.suffix || '';
        const duration = 1500;
        const start = performance.now();
        function tick(now: number) {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.floor(eased * target) + suffix;
          if (progress < 1) requestAnimationFrame(tick);
          else el.textContent = target + suffix;
        }
        requestAnimationFrame(tick);
        counterObserver.unobserve(el);
      }
    });
  }, { threshold: 0.5 });
  counters.forEach((c) => counterObserver.observe(c));

  // Image tilt
  const tilt = document.getElementById('about-tilt');
  tilt?.addEventListener('mousemove', (e) => {
    const rect = tilt.getBoundingClientRect();
    const x = (e.clientX - rect.left) / rect.width - 0.5;
    const y = (e.clientY - rect.top) / rect.height - 0.5;
    tilt.style.transform = `perspective(800px) rotateY(${x * 15}deg) rotateX(${-y * 15}deg)`;
  });
  tilt?.addEventListener('mouseleave', () => {
    tilt.style.transform = '';
  });
</script>

<style>
  #about-tilt {
    transition: transform 0.3s ease-out;
    will-change: transform;
  }
</style>
