---

<section id="contact" class="relative py-24 sm:py-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-aos="fade-up">
      <h2 class="text-sm font-semibold text-blue-400 tracking-wider uppercase mb-3">Contacto</h2>
      <h3 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-white">
        Trabajemos <span class="gradient-text">juntos</span>
      </h3>
      <p class="text-slate-400 text-lg mt-4 max-w-2xl mx-auto">
        Tienes un proyecto en mente? Me encantaría escuchar sobre él. Conectemos y hagamos algo increíble.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <a href="https://github.com/sheluvsale" target="_blank" rel="noopener noreferrer"
         class="card-lift gradient-border rounded-2xl p-8 text-center transition-all" data-aos="fade-right">
        <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-blue-500/10 flex items-center justify-center">
          <svg class="w-8 h-8 text-blue-400" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53.64 1.53.64.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02A9.6 9.6 0 0112 6.8c.85.004 1.71.11 2.51.32 1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z"/></svg>
        </div>
        <h4 class="text-xl font-bold text-white mb-2">GitHub</h4>
        <p class="text-slate-400 text-sm mb-4">@sheluvsale</p>
        <span class="inline-flex items-center gap-1 text-blue-400 text-sm font-medium">
          Visitar perfil
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </span>
      </a>

      <a href="https://www.instagram.com/ale.cast_28/" target="_blank" rel="noopener noreferrer"
         class="card-lift gradient-border rounded-2xl p-8 text-center transition-all" data-aos="fade-left">
        <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-pink-500/10 flex items-center justify-center">
          <svg class="w-8 h-8 text-pink-400" viewBox="0 0 24 24" fill="currentColor"><path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 01-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 017.8 2zm-.2 2A3.6 3.6 0 004 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 003.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6zm9.65 1.5a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5zM12 7a5 5 0 110 10 5 5 0 010-10zm0 2a3 3 0 100 6 3 3 0 000-6z"/></svg>
        </div>
        <h4 class="text-xl font-bold text-white mb-2">Instagram</h4>
        <p class="text-slate-400 text-sm mb-4">@ale.cast_28</p>
        <span class="inline-flex items-center gap-1 text-pink-400 text-sm font-medium">
          Seguirme
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </span>
      </a>
    </div>
  </div>
</section>
